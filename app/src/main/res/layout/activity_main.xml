<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:padding="16dp">

    <!-- ScrollView дозволяє гортати налаштування, не перекриваючи кнопку -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnApplyWallpaper"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Картка запиту дозволу -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/permissionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorErrorContainer"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Потрібен доступ до сповіщень"
                        android:textColor="?attr/colorOnErrorContainer"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.8"
                        android:text="Це необхідно для отримання обкладинок музики."
                        android:textColor="?attr/colorOnErrorContainer" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenSettings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Надати доступ" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Основна картка з налаштуваннями -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_blur"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="Enable Blur Effect"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:alpha="0.6"
                        android:text="Додає розмиття фону"
                        android:textSize="14sp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_blur"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="1.0"
                        android:value="120.0"
                        android:valueFrom="1.0"
                        android:valueTo="200.0" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_dark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:checked="true"
                        android:text="Darken Wallpaper"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:alpha="0.6"
                        android:text="Додає затемнення фону"
                        android:textSize="14sp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_dark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="0.1"
                        android:value="0.4"
                        android:valueFrom="0.1"
                        android:valueTo="1.0" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectApps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Вибрати додатки" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Кнопка застосування, прив'язана до низу -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyWallpaper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="Застосувати шпалери"
        android:textSize="16sp" />

</RelativeLayout>
